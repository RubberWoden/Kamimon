script/source = "class_name BaseScene extends Node

@onready var player = \"uid://bxf853jpgvgvs\"

func _ready() -> void:
	if scene_manager.player:
		if player:
			player.queue_free()
		
		player = scene_manager.player 
		add_child(player)
"

